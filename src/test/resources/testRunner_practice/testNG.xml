<?xml version="1.0" encoding="UTF-8"?><!-- this is a scheme difination-->


<suite name="TestNG Regression Suit" verbose="3" thread-count="3"
	parallel="tests">

	<test name="GoogleTest">
		<parameter name="url" value="https://www.google.com" />
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="TestNGPractice.oneTest" />
		</classes>
	</test>

	<test name="NaveenTest">
		<parameter name="url"
			value="https://naveenautomationlabs.com/opencart/index.php?route=account/login" />
		<parameter name="browser" value="edge" />
		<classes>
			<class name="TestNGPractice.secondTest" />
		</classes>
	</test>

	<test name="Orange HRM Test">
		<parameter name="url" value="https://orangehrm.com/en/30-day-free-trial" />
		<parameter name="browser" value="chrome" />

		<classes>
			<class name="TestNGPractice.ThirdTest" />
		</classes>

	</test>


</suite>


